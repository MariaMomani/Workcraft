@using Microsoft.AspNetCore.Identity
@using Workcraft.Models
@model Workcraft.ViewModels.UserProfileViewModel
@{
    Layout = "_UserLayout";
}

<div class="container-fluid py-5">
    <div class="mb-4">
        <h1 class="fw-bold mb-1">User Profile</h1>
        <p class="text-muted small">ID: @Model.Id.ToString().Substring(0, 8)...</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="profile-card p-4 text-center">
                <div class="mb-3">
                    <div class="avatar-circle">
                        <i class="fa-solid fa-user text-primary"></i>
                    </div>
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted small mb-3">@Model.Position</p>
                <span class="badge bg-soft-success text-success rounded-pill px-3">Active Member</span>

                <hr class="my-4 opacity-50">

                <div class="text-start">
                    <p class="profile-label">Personal Status</p>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small text-secondary">Verified Employee</span>
                        <i class="fa-solid fa-check-circle text-success"></i>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="small text-secondary">WorkCraft Rank</span>
                        <span class="badge bg-light text-dark border small">Level 1</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="profile-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Identity Details</h5>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="openEditProfileModal()">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Profile
                    </button>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="profile-label">Full Name</label>
                        <p class="profile-value">@Model.FullName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="profile-label">Email Address</label>
                        <p class="profile-value">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="profile-label">Phone Number</label>
                        <p class="profile-value">@(Model.PhoneNumber ?? "Not Linked")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="profile-label">Position</label>
                        <p class="profile-value text-primary">@Model.Position</p>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top">
                    <h5 class="fw-bold mb-3">Account Security</h5>
                    <div class="d-flex gap-2">
                        <button class="btn btn-light btn-sm px-3">
                            <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-light btn-sm px-3 border">
                                <i class="fa-solid fa-key me-1"></i> Change Password
                            </a>
                        </button>
                        <button class="btn btn-light btn-sm px-3 border">Privacy Settings</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="editProfileModal" class="modal">
    <div class="modal-content">
        <h3 class="fw-bold mb-3">Update Profile</h3>
        <form asp-controller="User" asp-action="UpdateProfile" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="small fw-bold text-uppercase text-muted">Full Name</label>
                <input asp-for="FullName" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="small fw-bold text-uppercase text-muted">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" />
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="button" class="btn btn-light w-100" onclick="closeEditProfileModal()">Cancel</button>
                <button type="submit" class="btn btn-primary w-100 text-white">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts{
    <script src="~/js/userProfile.js"></script>
}