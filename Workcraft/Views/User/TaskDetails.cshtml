@model List<Workcraft.Models.TaskItem>
@using Workcraft.Models.Enums
@{
    Layout = "_UserLayout";

    var pending = Model.Where(t => t.Status == WorkTaskStatus.Pending).ToList();
    var inProgress = Model.Where(t => t.Status == WorkTaskStatus.InProgress).ToList();
    var completed = Model.Where(t => t.Status == WorkTaskStatus.Completed).ToList();
    var rejected = Model.Where(t => t.Status == WorkTaskStatus.Rejected).ToList();
}

<div class="container mt-4" style="max-width: 980px;">

    <h2 style="font-size:26px; font-weight:600; color:#111827; margin-bottom:4px;">My Tasks</h2>
    <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Manage and track your assigned work</p>

    {{!-- Tab Buttons --}}
    <div class="tab-bar">
        <button class="tab-btn active" data-tab="all">
            All Tasks <span class="tab-count">@Model.Count</span>
        </button>
        <button class="tab-btn" data-tab="pending">
            Pending <span class="tab-count">@pending.Count</span>
        </button>
        <button class="tab-btn" data-tab="inprog">
            In Progress <span class="tab-count">@inProgress.Count</span>
        </button>
        <button class="tab-btn" data-tab="done">
            Done <span class="tab-count">@completed.Count</span>
        </button>
        <button class="tab-btn" data-tab="rejected">
            Rejected <span class="tab-count">@rejected.Count</span>
        </button>
    </div>

    <div class="tab-panel active" id="panel-all">

        @if (!Model.Any())
        {
            <div class="empty-state">No tasks assigned to you yet.</div>
        }

        @* Pending section *@
        @if (pending.Any())
        {
            <p class="section-label">Pending</p>
            <div class="table-wrap">
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in pending)
                        {
                            <tr>
                                <td>@task.Title</td>
                                <td>@task.Description</td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        @task.DueDate.Value.ToString("MMM d, yyyy")
                                    }
                                    else
                                    {
                                        <span>No deadline</span>
                                    }
                                </td>
                                <td>
                                    {{!-- Accept button --}}
                                    <form asp-action="AcceptTask" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.Id" />
                                        <button type="submit" class="btn-action btn-accept">Accept</button>
                                    </form>

                                    {{!-- Reject button --}}
                                    <form asp-action="RejectTask" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.Id" />
                                        <button type="submit" class="btn-action btn-reject">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (inProgress.Any())
        {
            <p class="section-label">In Progress</p>
            <div class="cards-grid">
                @foreach (var task in inProgress)
                {
                    <div class="task-card inprog-card">
                        <div class="card-top">
                            <div class="card-title">@task.Title</div>
                            <span class="badge badge-inprog">In Progress</span>
                        </div>

                        <div class="card-body">@task.Description</div>

                        <div class="card-footer">
                            <span>
                                Due:
                                @if (task.DueDate.HasValue)
                                {
                                    @task.DueDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span>No deadline</span>
                                }
                            </span>

                            {{!-- Mark as Done: status value 2 = Completed --}}
                            <form asp-action="ChangeTaskStatus" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <input type="hidden" name="status" value="2" />
                                <button type="submit" class="btn-done">Mark Done</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

        @if (completed.Any())
        {
            <p class="section-label">Completed</p>
            <div class="cards-grid">
                @foreach (var task in completed)
                {
                    <div class="task-card done-card">
                        <div class="card-top">
                            <div class="card-title">@task.Title</div>
                            <span class="badge badge-done">Completed</span>
                        </div>

                        <div class="card-body">@task.Description</div>

                        <div class="card-footer">
                            <span>
                                Due:
                                @if (task.DueDate.HasValue)
                                {
                                    @task.DueDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span>No deadline</span>
                                }
                            </span>

                            {{!-- Reopen: status value 1 = InProgress --}}
                            <form asp-action="ChangeTaskStatus" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <input type="hidden" name="status" value="1" />
                                <button type="submit" class="btn-revert">Reopen</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

        @if (rejected.Any())
        {
            <p class="section-label">Rejected</p>
            <div class="table-wrap">
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in rejected)
                        {
                            <tr>
                                <td>@task.Title</td>
                                <td>@task.Description</td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        @task.DueDate.Value.ToString("MMM d, yyyy")
                                    }
                                    else
                                    {
                                        <span>No deadline</span>
                                    }
                                </td>
                                <td><span class="badge badge-rejected">Rejected</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>

    <div class="tab-panel" id="panel-pending">
        @if (!pending.Any())
        {
            <div class="empty-state">No pending tasks right now.</div>
        }
        else
        {
            <div class="table-wrap">
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in pending)
                        {
                            <tr>
                                <td>@task.Title</td>
                                <td>@task.Description</td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        @task.DueDate.Value.ToString("MMM d, yyyy")
                                    }
                                    else
                                    {
                                        <span>No deadline</span>
                                    }
                                </td>
                                <td>
                                    <form asp-action="AcceptTask" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.Id" />
                                        <button type="submit" class="btn-action btn-accept">Accept</button>
                                    </form>
                                    <form asp-action="RejectTask" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.Id" />
                                        <button type="submit" class="btn-action btn-reject">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tab-panel" id="panel-inprog">
        @if (!inProgress.Any())
        {
            <div class="empty-state">No tasks in progress right now.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var task in inProgress)
                {
                    <div class="task-card inprog-card">
                        <div class="card-top">
                            <div class="card-title">@task.Title</div>
                            <span class="badge badge-inprog">In Progress</span>
                        </div>
                        <div class="card-body">@task.Description</div>
                        <div class="card-footer">
                            <span>
                                Due:
                                @if (task.DueDate.HasValue)
                                {
                                    @task.DueDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span>No deadline</span>
                                }
                            </span>
                            <form asp-action="ChangeTaskStatus" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <input type="hidden" name="status" value="2" />
                                <button type="submit" class="btn-done">Mark Done</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="tab-panel" id="panel-done">
        @if (!completed.Any())
        {
            <div class="empty-state">No completed tasks yet.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var task in completed)
                {
                    <div class="task-card done-card">
                        <div class="card-top">
                            <div class="card-title">@task.Title</div>
                            <span class="badge badge-done">Completed</span>
                        </div>
                        <div class="card-body">@task.Description</div>
                        <div class="card-footer">
                            <span>
                                Due:
                                @if (task.DueDate.HasValue)
                                {
                                    @task.DueDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span>No deadline</span>
                                }
                            </span>
                            <form asp-action="ChangeTaskStatus" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <input type="hidden" name="status" value="1" />
                                <button type="submit" class="btn-revert">Reopen</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="tab-panel" id="panel-rejected">
        @if (!rejected.Any())
        {
            <div class="empty-state">No rejected tasks.</div>
        }
        else
        {
            <div class="table-wrap">
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in rejected)
                        {
                            <tr>
                                <td>@task.Title</td>
                                <td>@task.Description</td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        @task.DueDate.Value.ToString("MMM d, yyyy")
                                    }
                                    else
                                    {
                                        <span>No deadline</span>
                                    }
                                </td>
                                <td><span class="badge badge-rejected">Rejected</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script src="~/js/taskDetails.js"></script>
}