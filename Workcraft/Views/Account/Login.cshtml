@using Workcraft.ViewModels;
@model LoginViewModel;
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 90vh;">
    <div class="account-box" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-4">
            <h1 class="fw-bold" style="background: linear-gradient(to right, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 2.5rem;">WorkCraft</h1>
            <p class="text-secondary">Welcome back, Boss.</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small text-uppercase fw-bold text-secondary">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="name@workcraft.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label asp-for="Password" class="form-label small text-uppercase fw-bold text-secondary">Password</label>
                    <a asp-controller="Account" asp-action="VerifyEmail" class="small text-decoration-none text-accent-blue">Forgot?</a>
                </div>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label class="form-check-label small text-secondary">Keep me signed in</label>
            </div>

            <button type="submit" class="btn btn-modern w-100 p-3">Launch Workspace</button>

            <p class="text-center mt-4 text-secondary small">
                New here? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-accent-purple">Create Account</a>
            </p>
        </form>
    </div>
</div>