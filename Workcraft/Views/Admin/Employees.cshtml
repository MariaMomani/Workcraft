@model Workcraft.Models.ViewModels.EmployeesPageViewModel
@{
    Layout = "_AdminLayout";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-3" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-3" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="squad-page">


    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="fw-bold mb-1" style="font-size:24px">Squad Management</h1>
            <p class="text-muted small mb-0">Manage your team members and their operational status.</p>
        </div>
        <button class="btn-add-agent" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Add Agent
        </button>
    </div>


    <div class="stat-grid-new">
        <div class="stat-card-new">
            <div class="stat-label"><i class="fa-solid fa-users me-1 text-primary"></i> Total Squad</div>
            <p class="stat-value">@Model.TotalEmployees</p>
        </div>
        <div class="stat-card-new">
            <div class="stat-label"><i class="fa-solid fa-user-check me-1 text-success"></i> Active</div>
            <p class="stat-value" style="color:#22c55e">@Model.ActiveEmployees</p>
        </div>
        <div class="stat-card-new">
            <div class="stat-label"><i class="fa-solid fa-user-clock me-1 text-danger"></i> Busy</div>
            <p class="stat-value" style="color:#ef4444">@Model.BusyEmployees</p>
        </div>
    </div>


    <div class="team-header">
        <h2>Team Members</h2>
        <div class="team-controls">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="searchInput" placeholder="Search employees..." oninput="filterCards()" />
            </div>
            <div class="filter-group">
                <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
                <button class="filter-btn" onclick="setFilter('available', this)">Available</button>
                <button class="filter-btn" onclick="setFilter('busy', this)">Busy</button>
            </div>
        </div>
    </div>


    <div class="cards-grid" id="cardsGrid">
        @{
            string[] avColors = { "av-blue", "av-green", "av-yellow", "av-purple", "av-pink", "av-orange", "av-teal", "av-red" };
            int colorIdx = 0;
        }
        @foreach (var employee in Model.Employees)
        {
            var status = employee.Status ?? "Available";
            var statusLower = status.ToLower();
            var dotClass = statusLower switch
            {
                "available" => "dot-available",
                "busy" => "dot-busy",
                "break" => "dot-break",
                _ => "dot-offline"
            };
            var statusColor = statusLower switch
            {
                "available" => "#16a34a",
                "busy" => "#b45309",
                "break" => "#b45309",
                _ => "#6c757d"
            };
            var avColor = avColors[colorIdx % avColors.Length];
            colorIdx++;
            var initials = string.Concat(
            employee.FullName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0].ToString().ToUpper()));

            <div class="emp-card" data-status="@statusLower" data-name="@employee.FullName.ToLower()">
                <div class="emp-card-header">
                    <div class="avatar-circle @avColor">
                        @initials
                        <span class="avatar-dot @dotClass"></span>
                    </div>
                    <div>
                        <p class="emp-name">@employee.FullName</p>
                        <p class="emp-role">@employee.Position</p>
                        <p class="emp-status-line">
                            <span class="status-dot-inline @dotClass"></span>
                            <span style="color:@statusColor">@status</span>
                        </p>
                    </div>
                </div>

                <hr class="emp-divider" />

                <div class="emp-stat-row">
                    <span>Active Tasks</span>
                    <span>
                        @if (Model.TaskStats.ContainsKey(employee.Id))
                        {
                            @Model.TaskStats[employee.Id].ActiveTasks
                        }
                        else
                        {
                            <span>0</span>
                        }
                    </span>
                </div>

                <div class="emp-stat-row">
                    <span>Completed</span>
                    <span>
                        @if (Model.TaskStats.ContainsKey(employee.Id))
                        {
                            @Model.TaskStats[employee.Id].CompletedTasks
                        }
                        else
                        {
                            <span>0</span>
                        }
                    </span>
                </div>

                <div class="emp-stat-row">
                    <span>Email</span>
                    <span style="font-size:12px; font-weight:400; color:#6c757d">@employee.Email</span>
                </div>

                <div class="emp-card-actions">
                    <button class="btn-view-profile edit-btn"
                            data-id="@employee.Id"
                            data-name="@employee.FullName"
                            data-email="@employee.Email"
                            data-status="@status"
                            data-position="@employee.Position">
                        View Profile
                    </button>

                    <a class="btn-icon-action" href="mailto:@employee.Email" title="Email">
                        <i class="fa-regular fa-envelope"></i>
                    </a>

                    <form asp-action="DeleteEmployee" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@employee.Id" />
                        <button type="submit" class="btn-icon-action"
                                title="Delete"
                                style="color:#ef4444"
                                onclick="return confirm('Terminate Agent access?')">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>


<div id="addEmployeeModal" class="modal-overlay">
    <div class="modal-box">
        <h3>Add New Agent</h3>
        <form asp-action="AddEmployee" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="NewEmployee.FullName" class="form-control" placeholder="John Doe" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input asp-for="NewEmployee.Email" class="form-control" placeholder="john@workcraft.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Temp Password</label>
                <input asp-for="NewEmployee.Password" type="password" class="form-control" placeholder="Enter a temporary password" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Position</label>
                <select asp-for="NewEmployee.Position" class="form-select">
                    <option value="">-- Select Position --</option>
                    @foreach (var pos in Workcraft.Helpers.PositionHelper.Positions)
                    {
                        <option value="@pos">@pos</option>
                    }
                </select>
                <span asp-validation-for="NewEmployee.Position" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="button" class="btn-modal-cancel" onclick="closeAddModal()">Cancel</button>
                <button type="submit" class="btn-modal-save">Save Agent</button>
            </div>
        </form>
    </div>
</div>


<div id="editEmployeeModal" class="modal-overlay">
    <div class="modal-box">
        <h3>Edit Agent Details</h3>
        <form asp-action="EditEmployee" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="Id" />
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" id="editFullName" name="FullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" id="editEmail" name="Email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Position</label>
                <select id="editPosition" name="Position" class="form-select">
                    <option value="">-- Select Position --</option>
                    @foreach (var pos in Workcraft.Helpers.PositionHelper.Positions)
                    {
                        <option value="@pos">@pos</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="button" class="btn-modal-cancel" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn-modal-save">Update Info</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/employees.js"></script>
}
