@model Workcraft.ViewModels.DashboardViewModel
@{
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted">Monitor team productivity and manage tasks efficiently</p>
        </div>

        <a href="/Admin/Tasks" class="btn btn-primary px-4 py-2 shadow-sm">
            <i class="fa fa-plus me-2"></i> New Task
        </a>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card dashboard-card">
                <div>
                    <p>Total Employees</p>
                    <h3>@Model.TotalEmployees</h3>
                    <span class="text-success small">↑ 2 new this month</span>
                </div>
                <i class="fa fa-users icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card">
                <div>
                    <p>Available Now</p>
                    <h3>@Model.AvailableEmployees</h3>
                    <span class="text-success small">↑ Ready</span>
                </div>
                <i class="fa fa-check-circle icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card">
                <div>
                    <p>Active Tasks</p>
                    <h3>@Model.TasksInProgress</h3>
                    <span class="text-danger small">↓ Due soon</span>
                </div>
                <i class="fa fa-clock icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card">
                <div>
                    <p>Completion Rate</p>
                    <h3>@Model.CompletionRate%</h3>
                    <span class="text-success small">↑ +5%</span>
                </div>
                <i class="fa fa-chart-line icon"></i>
            </div>
        </div>

    </div>

    <div class="card p-4 shadow-sm chart-card">
        <h5 class="mb-3">Weekly Productivity</h5>
        <canvas id="productivityChart" height="100"></canvas>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // const completedData = @Html.Raw(Json.Serialize(Model.WeeklyCompleted));
        const inProgressData = @Html.Raw(Json.Serialize(Model.WeeklyInProgress));

        const ctx = document.getElementById('productivityChart');

        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [
                        // {
                        //     label: 'Completed Tasks',
                        //     data: completedData,
                        //     borderColor: '#4e73df',
                        //     backgroundColor: 'rgba(78,115,223,0.1)',
                        //     fill: true,
                        //     tension: 0.4
                        // },
                        {
                            label: 'In Progress',
                            data: inProgressData,
                            borderColor: '#e74a3b',
                            backgroundColor: 'rgba(231,74,59,0.1)',
                            fill: true,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: true }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });
        }
    </script>
}