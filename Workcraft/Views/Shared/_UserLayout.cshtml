<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WorkCraft - User</title>
    <link rel="stylesheet" href="~/css/user.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <div class="user-container">
        <aside class="user-sidebar">
            <div class="logo-section">
                <div class="logo-circle">WC</div>
                <div class="logo-text">WorkCraft</div>
            </div>

            <nav class="user-menu">
                <a asp-controller="User" asp-action="Dashboard"
                   class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-house"></i> Dashboard
                </a>
                <a asp-controller="User" asp-action="TaskDetails"
                   class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "TaskDetails" ? "active" : "")">
                    <i class="fa-solid fa-list-check"></i> Task Details
                </a>
                <a asp-controller="User" asp-action="Profile"
                   class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="fa-solid fa-user"></i> My Profile
                </a>
            </nav>

            <div class="logout-section">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="user-logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </form>
            </div>
        </aside>

        <main class="user-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>